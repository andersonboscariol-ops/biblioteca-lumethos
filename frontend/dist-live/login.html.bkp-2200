<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<title>Biblioteca Teológica do Pregador — Login</title>
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon.png">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg-primary: #0D1B2A;
  --bg-secondary: #0a1628;
  --bg-tertiary: #0f1d30;
  --bg-card: rgba(255,255,255,0.03);
  --bg-glass: rgba(255,255,255,0.04);
  --border-color: rgba(199,154,46,0.12);
  --border-glass: rgba(255,255,255,0.06);
  --gold: #C79A2E;
  --gold-dark: #a7811e;
  --gold-light: #e0b84c;
  --gold-glow: rgba(199,154,46,0.25);
  --text-primary: #E8E6E3;
  --text-secondary: #9BA4B0;
  --text-dim: #6B7280;
  --success: #22c55e;
  --success-glow: rgba(34,197,94,0.2);
  --danger: #ef4444;
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 20px;
  --glass-bg: rgba(13,27,42,0.6);
  --glass-border: rgba(255,255,255,0.06);
  --glass-shadow: 0 8px 32px rgba(0,0,0,0.3);
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: 'Inter', sans-serif;
  background: var(--bg-primary);
  color: var(--text-primary);
  min-height: 100vh;
  overflow-x: hidden;
}
body::before {
  content: ''; position: fixed; inset: 0;
  background-image:
    radial-gradient(ellipse at 10% 10%, rgba(199,154,46,0.03) 0%, transparent 50%),
    radial-gradient(ellipse at 90% 90%, rgba(59,130,246,0.03) 0%, transparent 50%);
  pointer-events: none; z-index: 0;
}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(199,154,46,0.3); border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: rgba(199,154,46,0.5); }

/* ===== LOGIN PAGE ===== */
.login-page {
  min-height: 100vh; display: flex; align-items: center; justify-content: center;
  background: linear-gradient(160deg, #0a1628 0%, #0D1B2A 50%, #07152b 100%);
  padding: 20px;
}
.login-page::before {
  content: ''; position: fixed; inset: 0; pointer-events: none;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(199,154,46,0.04) 0%, transparent 40%),
    radial-gradient(circle at 80% 70%, rgba(199,154,46,0.02) 0%, transparent 40%);
}
.login-card-toplink {
  position: absolute;
  top: 12px;
  left: 14px;
  z-index: 2;
}
.login-card-toplink a {
  font-size: 11px;
  color: #6b7a8a;
  text-decoration: none;
  transition: color .2s;
}
.login-card-toplink a:hover {
  color: #8899aa;
}
.login-card {
  position: relative;
  display: flex; max-width: 860px; width: 100%; border-radius: var(--radius-lg);
  overflow: hidden; box-shadow: 0 25px 60px rgba(0,0,0,0.5);
}
.login-card .login-left { border-radius: var(--radius-lg) 0 0 var(--radius-lg); }
.login-card .login-right { border-radius: 0 var(--radius-lg) var(--radius-lg) 0; }
}

/* ===== LEFT COLUMN ===== */
.login-left {
  flex: 1; background: linear-gradient(160deg, #132f5a 0%, #0b2242 45%, #07152b 100%);
  padding: 48px 36px; display: flex; flex-direction: column; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
.login-left::before {
  content: ''; position: absolute; inset: 0;
  background-image:
    radial-gradient(circle at 20% 50%, rgba(199,154,46,0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(199,154,46,0.05) 0%, transparent 50%);
  animation: pulse-glow 4s ease-in-out infinite;
}
@keyframes pulse-glow {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}
.login-badge {
  font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold);
  padding: 6px 16px; border: 1px solid rgba(199,154,46,0.3); border-radius: 20px;
  margin-bottom: 20px; font-weight: 600; z-index: 1;
}
.login-left h1 { color: #fff; font-size: 26px; font-weight: 700; text-align: center; z-index: 1; margin-bottom: 8px; font-family: Georgia, 'Times New Roman', serif; }
.login-left p { color: var(--text-secondary); font-size: 13px; text-align: center; z-index: 1; line-height: 1.5; }
.login-logo { width: 100%; max-width: 280px; margin-bottom: 16px; z-index: 1; }
.login-logo img { width: 100%; height: auto; border-radius: 50%; }

/* ===== RIGHT COLUMN ===== */
.login-right {
  flex: 1; background: #fff; padding: 48px 36px;
  display: flex; flex-direction: column; justify-content: center;
}
.login-right h2 { color: #1a1a1a; font-size: 22px; font-weight: 700; margin-bottom: 4px; }
.login-right .login-sub { color: #666; font-size: 13px; margin-bottom: 28px; }

/* ===== FORM ===== */
.form-group { margin-bottom: 18px; }
.form-group label { display: block; color: #333; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
.form-group input {
  width: 100%; padding: 11px 14px; border: 1px solid #d1d5db; border-radius: 8px;
  font-size: 14px; font-family: 'Inter', sans-serif; transition: all .25s;
  outline: none; background: #f9fafb;
}
.form-group input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(199,154,46,0.15); background: #fff; }
.form-group input.error { border-color: var(--danger); box-shadow: 0 0 0 3px rgba(239,68,68,0.15); }

/* ===== PASSWORD TOGGLE ===== */
.password-wrapper { position: relative; }
.password-wrapper input { padding-right: 42px !important; }
.toggle-password {
  position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
  background: none; border: none; cursor: pointer; padding: 6px;
  color: #888; transition: color .2s; line-height: 1;
}
.toggle-password:hover { color: var(--gold); }
.toggle-password .eye-icon { display: block; }
.form-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
.form-check { display: flex; align-items: center; gap: 6px; }
.form-check input[type="checkbox"] { width: 16px; height: 16px; accent-color: var(--gold); cursor: pointer; }
.form-check label { color: #555; font-size: 13px; cursor: pointer; }
.forgot-link { font-size: 13px; color: var(--gold); text-decoration: none; font-weight: 600; cursor: pointer; opacity: 0.5; pointer-events: none; }

/* ===== BUTTON ===== */
.login-btn {
  width: 100%; padding: 12px; background: linear-gradient(135deg, var(--gold), var(--gold-dark));
  color: #fff; border: none; border-radius: 8px; font-size: 15px; font-weight: 600;
  cursor: pointer; transition: all .3s; font-family: 'Inter', sans-serif;
  position: relative; overflow: hidden;
}
.login-btn::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.1) 50%, transparent 60%);
  transform: translateX(-100%); transition: transform .5s;
}
.login-btn:hover::after { transform: translateX(100%); }
.login-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 20px var(--gold-glow); background: linear-gradient(135deg, var(--gold-light), var(--gold)); }
.login-btn:active { transform: scale(.98); }
.login-btn:disabled { opacity: .6; cursor: not-allowed; }
.login-btn.is-loading { pointer-events: none; }
.login-btn.is-loading::after {
  content: ''; position: absolute; right: 16px; top: 50%;
  transform: translateY(-50%); width: 18px; height: 18px;
  border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%;
  animation: fm-spin .8s linear infinite;
}
@keyframes fm-spin { from { transform: translateY(-50%) rotate(0deg); } to { transform: translateY(-50%) rotate(360deg); } }

/* ===== MESSAGE ===== */
.login-msg { font-size: 13px; margin-top: 12px; text-align: center; display: none; height: 20px; }
.login-msg.show { display: block; }
.login-msg.error { color: var(--danger); }
.login-msg.success { color: var(--success); }

/* ===== FOOTER ===== */
.login-footer { text-align: center; margin-top: 20px; font-size: 13px; color: #777; }
.login-footer a { color: var(--gold); font-weight: 700; text-decoration: none; cursor: pointer; }
.login-footer a:hover { opacity: .8; }

/* ===== SECTIONS ===== */
#register-section { display: none; }

/* ===== RESPONSIVE ===== */
@media (max-width: 767px) {
  .login-page {
    padding: 0;
    align-items: stretch;
    min-height: 100dvh;
  }
  .login-card {
    flex-direction: column;
    max-width: 100%;
    min-height: 100dvh;
    border-radius: 0;
    box-shadow: none;
  }
  .login-left {
    flex: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 24px 12px;
    border-radius: 0;
    text-align: center;
  }
  .login-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow-y: auto;
    padding: 8px 24px 24px;
    border-radius: 0;
  }
  .login-left h1 { font-size: 18px; text-align: center; }
  .login-logo { max-width: 120px; margin-bottom: 4px; }
  .login-left p { font-size: 12px; }
  .login-badge { font-size: 9px; padding: 3px 12px; letter-spacing: 1.5px; margin-bottom: 4px; }
  .login-card-toplink { top: 4px; left: 8px; }
  .login-card-toplink a { font-size: 10px; }
  .login-right h2 { font-size: 18px; text-align: center; }
  .login-right .login-sub { margin-bottom: 10px; font-size: 13px; text-align: center; }
  .form-group { margin-bottom: 10px; }
  .form-group input { padding: 10px 12px; font-size: 14px; }
  .login-btn { padding: 11px; font-size: 14px; }
}
</style>
</head>
<body>

<div class="login-page">
  <div class="login-card">
      <div class="login-card-toplink"><a href="https://institutolumethos.online">Voltar ao site principal</a></div>

    <!-- LEFT — Gradiente escuro com glow -->
    <div class="login-left">
      <span class="login-badge">BIBLIOTECA LUMETHOS</span>
      <div class="login-logo">
        <img src="/logo-biblioteca.png?v=1" alt="Biblioteca Teológica do Pregador">
      </div>
      <h1>Biblioteca Teológica do Pregador</h1>
      <p>Acesse uma coleção completa de livros teológicos, comentários, dicionários e materiais de estudo.</p>
      <!-- back-link movido pra .login-topbar -->
    </div>

    <!-- RIGHT — Formulário -->
    <div class="login-right">

      <!-- LOGIN SECTION -->
      <div id="login-section">
        <h2>Bem-vindo de volta</h2>
        <p class="login-sub">Faça login para continuar</p>

        <form id="loginForm" autocomplete="on" novalidate>
          <div class="form-group">
            <label>E-mail</label>
            <input type="email" id="loginEmail" placeholder="seu@email.com" required autocomplete="email">
          </div>
          <div class="form-group">
            <label>Senha</label>
            <div class="password-wrapper">
              <input type="password" id="loginPassword" placeholder="••••••••" required autocomplete="current-password">
              <button type="button" class="toggle-password" onclick="togglePassword('loginPassword', this)" tabindex="-1" aria-label="Mostrar senha">
                <svg class="eye-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>
          <div class="form-row">
            <label class="form-check">
              <input type="checkbox" id="rememberMe" checked>
              <label for="rememberMe">Lembrar-me</label>
            </label>
            <span class="forgot-link">Esqueci a senha</span>
          </div>
          <button type="submit" class="login-btn" id="loginBtn">Entrar</button>
        </form>

        <div class="login-msg" id="loginMsg"></div>

        <div class="login-footer">
          Ainda não tem conta? <a href="#" id="showRegisterLink">Cadastre-se</a>
        </div>
      </div>

      <!-- REGISTER SECTION -->
      <div id="register-section">
        <h2>Criar sua conta</h2>
        <p class="login-sub">Cadastre-se e escolha seu plano de acesso</p>

        <form id="registerForm" autocomplete="on" novalidate>
          <div class="form-group">
            <label>Nome completo</label>
            <input type="text" id="regName" placeholder="Seu nome" required autocomplete="name">
          </div>
          <div class="form-group">
            <label>E-mail</label>
            <input type="email" id="regEmail" placeholder="seu@email.com" required autocomplete="email">
          </div>
          <div class="form-group">
            <label>Senha</label>
            <div class="password-wrapper">
              <input type="password" id="regPassword" placeholder="Mínimo 6 caracteres" required minlength="6" autocomplete="new-password">
              <button type="button" class="toggle-password" onclick="togglePassword('regPassword', this)" tabindex="-1" aria-label="Mostrar senha">
                <svg class="eye-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>
          <button type="submit" class="login-btn" id="registerBtn">Criar Conta</button>
        </form>

        <div class="login-msg" id="registerMsg"></div>

        <div class="login-footer">
          Já tem conta? <a href="#" id="showLoginLink">Fazer login</a>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
(function() {
  const API = window.location.origin;

  // DOM
  const loginSection = document.getElementById('login-section');
  const registerSection = document.getElementById('register-section');
  const loginForm = document.getElementById('loginForm');
  const registerForm = document.getElementById('registerForm');
  const loginMsg = document.getElementById('loginMsg');
  const registerMsg = document.getElementById('registerMsg');
  const loginBtn = document.getElementById('loginBtn');
  const registerBtn = document.getElementById('registerBtn');

  // Toggle sections
  document.getElementById('showRegisterLink').addEventListener('click', function(e) {
    e.preventDefault();
    loginSection.style.display = 'none';
    registerSection.style.display = 'block';
    loginMsg.className = 'login-msg';
  });
  document.getElementById('showLoginLink').addEventListener('click', function(e) {
    e.preventDefault();
    loginSection.style.display = 'block';
    registerSection.style.display = 'none';
    registerMsg.className = 'login-msg';
  });

  // Helper
  function setLoading(btn, loading, text) {
    if (loading) {
      btn.classList.add('is-loading');
      btn.disabled = true;
      btn.textContent = text;
    } else {
      btn.classList.remove('is-loading');
      btn.disabled = false;
      btn.textContent = text;
    }
  }

  function showMsg(el, text, type) {
    el.textContent = text;
    el.className = 'login-msg show ' + type;
  }

  // ===== LOGIN =====
  loginForm.addEventListener('submit', function(e) {
    e.preventDefault();
    loginMsg.className = 'login-msg';
    setLoading(loginBtn, true, 'Entrando...');

    var email = document.getElementById('loginEmail').value.trim();
    var password = document.getElementById('loginPassword').value;

    fetch(API + '/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, password: password })
    })
    .then(function(r) {
      return r.json().then(function(d) { return { status: r.status, data: d }; });
    })
    .then(function(res) {
      if (res.status !== 200 && res.status !== 201) {
        throw new Error(res.data.error || 'Email ou senha inválidos');
      }
      localStorage.setItem('biblioteca_token', res.data.token);
      window.location.href = '/app';
    })
    .catch(function(err) {
      showMsg(loginMsg, err.message, 'error');
      setLoading(loginBtn, false, 'Entrar');
    });
  });

  // ===== REGISTER =====
  registerForm.addEventListener('submit', function(e) {
    e.preventDefault();
    registerMsg.className = 'login-msg';
    setLoading(registerBtn, true, 'Criando...');

    var name = document.getElementById('regName').value.trim();
    var email = document.getElementById('regEmail').value.trim();
    var password = document.getElementById('regPassword').value;

    fetch(API + '/api/auth/register', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: name, email: email, password: password })
    })
    .then(function(r) {
      return r.json().then(function(d) { return { status: r.status, data: d }; });
    })
    .then(function(res) {
      if (res.status !== 200 && res.status !== 201) {
        throw new Error(res.data.error || 'Erro ao criar conta');
      }
      localStorage.setItem('biblioteca_token', res.data.token);
      showMsg(registerMsg, 'Conta criada! Redirecionando...', 'success');
      window.location.href = '/app';
    })
    .catch(function(err) {
      showMsg(registerMsg, err.message, 'error');
      setLoading(registerBtn, false, 'Criar Conta');
    });
  });

  // ===== AUTO-REDIRECT IF LOGGED IN =====
  var token = localStorage.getItem('biblioteca_token');
  if (token) {
    fetch(API + '/api/auth/me', {
      headers: { 'Authorization': 'Bearer ' + token }
    })
    .then(function(r) {
      if (r.ok) window.location.href = '/app';
    })
    .catch(function() {});
  }
})();

function togglePassword(inputId, btn) {
  var input = document.getElementById(inputId);
  if (!input) return;
  var isPassword = input.type === 'password';
  input.type = isPassword ? 'text' : 'password';
  btn.setAttribute('aria-label', isPassword ? 'Ocultar senha' : 'Mostrar senha');
}
</script>

</body>
</html>
